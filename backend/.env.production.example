# ==========================================
# PRODUCTION CONFIGURATION FOR HOSTINGER
# ==========================================

APP_NAME=MOHADRIVE
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.mohadrive.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ==========================================
# DATABASE (Configure in Hostinger MySQL)
# ==========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mohadrive_production
DB_USERNAME=root
DB_PASSWORD=your_database_password

# ==========================================
# SESSION & CACHE (File driver for shared hosting)
# ==========================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.mohadrive.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none

CACHE_STORE=file
CACHE_PREFIX=

QUEUE_CONNECTION=sync

# ==========================================
# FRONTEND (Next.js on Vercel)
# ==========================================
FRONTEND_URL=https://mohadrive.com

# ==========================================
# MAIL - Resend (3000 emails free/month)
# ==========================================
MAIL_MAILER=resend
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM_ADDRESS=contact@mohadrive.com
MAIL_FROM_NAME=MOHADRIVE

# ==========================================
# OPTIONAL: Redis (if available)
# ==========================================
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ==========================================
# SANCTUM CONFIGURATION
# ==========================================
SANCTUM_STATEFUL_DOMAINS=mohadrive.com,api.mohadrive.com,localhost:3000,127.0.0.1:3000
